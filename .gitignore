# macOS
.DS_Store

# Node
node_modules/

# Python (legacy v1 reference tooling)
__pycache__/
*.pyc

# Claude Code transient / local — the whole dir: it also holds private local
# notes (.claude/scratch-pad/) that must never reach this public repo
.claude/

# Joust Engine run scratch — NEVER committed (the dogfood inbox is the durable path)
.runs/
**/.runs/
.bench/
**/.bench/

# Rebrand output — the generated "@@DE Development Engine" dev channel (bin/rebrand.mjs).
# Gitignored so the canonical source stays byte-for-byte identical and the same commit
# promotes to GitHub unchanged. Regenerate locally with: node bin/rebrand.mjs
.dev-engine/
